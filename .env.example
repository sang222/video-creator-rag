VCOS_APP_NAME=VCOS
VCOS_ENVIRONMENT=local
VCOS_DATABASE_URL=postgresql+psycopg://vcos:vcos@localhost:55432/vcos
VCOS_LOG_LEVEL=INFO
OLLAMA_BASE_URL=http://localhost:11434
VCOS_API_PORT=8000
VCOS_FRONTEND_PORT=3000
VCOS_DOCKER_DATABASE_URL=postgresql+psycopg://vcos:vcos@postgres:5432/vcos
VCOS_DOCKER_OLLAMA_BASE_URL=http://ollama:11434
VCOS_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_VCOS_API_BASE_URL=http://localhost:8000
VCOS_LLM_PROVIDER=ollama
VCOS_LLM_REAL_EXECUTION_ENABLED=false
VCOS_LLM_ROUTER_REAL_SMOKE=false

# M12.2 production prompt activation. Media/upload/publish stay disabled.
VCOS_ENABLE_PRODUCTION_PROMPT_ACTIVATION=false
VCOS_ENABLE_REAL_LLM_PACKAGE_RUN=false
VCOS_DISABLE_MEDIA_PROVIDER_CALLS=true
VCOS_DISABLE_UPLOAD_AND_PUBLISH=true
VCOS_DISABLE_OLD_PROVIDER_SMOKE=true

# M12 AI budget display. These are hard env caps only, not actual spend tracking.
VCOS_BUDGET_MODE=hard_env
VCOS_MONTHLY_AI_BUDGET_USD=250
VCOS_LLM_MONTHLY_BUDGET_USD=
VCOS_LLM_BUDGET_NOTE=Local Ollama/router budget cap, display only.

# Media provider API keys. Non-Veo real media provider execution remains disabled unless a later milestone enables it.
# Keep real values only in local .env or a secret manager; never commit them.
VCOS_VOICE_PROVIDER=elevenlabs
VCOS_ELEVENLABS_PLAN=creator
VCOS_ELEVENLABS_MONTHLY_CAP_USD=22
VCOS_ELEVENLABS_MONTHLY_CREDIT_CAP=121000
VCOS_ELEVENLABS_BUDGET_BASIS=credits_characters
VCOS_ELEVENLABS_REAL_ACCOUNT_SMOKE=false
ELEVENLABS_API_KEY=
VCOS_RENDER_PROVIDER=creatomate
CREATOMATE_PLAN=growth_10k
CREATOMATE_MONTHLY_CREDITS=10000
CREATOMATE_MONTHLY_BUDGET_USD=149
VCOS_CREATOMATE_REAL_ACCOUNT_SMOKE=false
CREATOMATE_API_KEY=
# Cloud Final Renderer remains a required gap in M12; do not point it at Creatomate light rendering.
CLOUD_FINAL_RENDERER_PROVIDER=
CLOUD_FINAL_RENDERER_API_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Google Vertex / Veo. Service account JSON must stay outside the repo.
VCOS_AI_HERO_PROVIDER=google_vertex_veo
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service_account.json
VCOS_VEO_MODEL_ID=veo-3.1-fast-generate-001
VCOS_VEO_MODE=video_only
VCOS_VEO_RESOLUTION=1080p
VCOS_VEO_AUDIO_ENABLED=false
VCOS_VEO_DEFAULT_DURATION_SECONDS=8
VCOS_VEO_MAX_DURATION_SECONDS=8
VCOS_VEO_COST_PER_SECOND_1080P=0.10
VCOS_VEO_MONTHLY_CAP_USD=75
VCOS_VEO_REAL_EXECUTION_ENABLED=false
VCOS_VEO_REAL_SMOKE=false

# M10.3 YouTube follow monitoring. Keep real values only in local .env.
YOUTUBE_PUBLIC_MONITOR_ENABLED=false
YOUTUBE_DATA_API_KEY=
YOUTUBE_OWNER_ANALYTICS_ENABLED=false
YOUTUBE_OAUTH_CLIENT_SECRETS_FILE=/absolute/path/to/client_secret.json
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/youtube/callback
YOUTUBE_OAUTH_SCOPES=https://www.googleapis.com/auth/youtube.readonly,https://www.googleapis.com/auth/yt-analytics.readonly
YOUTUBE_TEST_VIDEO_ID=
VCOS_YOUTUBE_REAL_PUBLIC_SMOKE=false
VCOS_YOUTUBE_REAL_OWNER_SMOKE=false

# M10.5 Google Drive media offload. OAuth client JSON/token files must stay outside git.
GOOGLE_DRIVE_OFFLOAD_ENABLED=false
GOOGLE_DRIVE_OAUTH_CLIENT_SECRETS_FILE=/absolute/path/to/client_secret.json
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google-drive/callback
GOOGLE_DRIVE_OAUTH_SCOPES=https://www.googleapis.com/auth/drive.file
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_UPLOAD_MODE=resumable
VCOS_DELETE_LOCAL_AFTER_DRIVE_UPLOAD=true
VCOS_LOCAL_MEDIA_MAX_AGE_HOURS=24
VCOS_LOCAL_MEDIA_MAX_STORAGE_GB=20
VCOS_DRIVE_REAL_UPLOAD_SMOKE=false

# Disabled optional spend in M12 display.
VCOS_STOCK_MONTHLY_BUDGET_USD=0
VCOS_MUSIC_SFX_MONTHLY_BUDGET_USD=0
VCOS_EXTRA_AI_IMAGE_MONTHLY_BUDGET_USD=0

# M11.1 local/dev dashboard auth. Set a real local password only in .env.
VCOS_DASHBOARD_AUTH_ENABLED=true
VCOS_AUTH_MODE=local_password
VCOS_BOOTSTRAP_ADMIN_EMAIL=admin@local.vcos
VCOS_BOOTSTRAP_ADMIN_PASSWORD=
VCOS_BOOTSTRAP_ADMIN_ROLE=OWNER_ADMIN
VCOS_AUTH_SESSION_TTL_HOURS=24

# LLM router lane-role model config. Agents map to lanes; models are defined by lane role.
VCOS_LLM_MODEL_CHEAP_STRUCTURED_PRIMARY=gpt-oss:20b-cloud
VCOS_LLM_MODEL_CHEAP_STRUCTURED_FALLBACK=qwen3.5:cloud
VCOS_LLM_MODEL_DEFAULT_MULTIMODAL_PRIMARY=qwen3.5:cloud
VCOS_LLM_MODEL_DEFAULT_MULTIMODAL_FALLBACK=gemma4:31b-cloud
VCOS_LLM_MODEL_VISUAL_CREATIVE_REVIEW_PRIMARY=minimax-m3:cloud
VCOS_LLM_MODEL_VISUAL_CREATIVE_REVIEW_FALLBACK=qwen3.5:cloud
VCOS_LLM_MODEL_VISUAL_CREATIVE_REVIEW_EMERGENCY=gemma4:31b-cloud
VCOS_LLM_MODEL_LONG_CONTEXT_TEXT_PRIMARY=deepseek-v4-flash:cloud
VCOS_LLM_MODEL_LONG_CONTEXT_TEXT_FALLBACK=nemotron-3-super:cloud
VCOS_LLM_MODEL_LONG_CONTEXT_TEXT_PREMIUM=deepseek-v4-flash:cloud
VCOS_LLM_MODEL_ENGINEERING_ARCHITECT_PRIMARY=qwen3-coder:480b-cloud
VCOS_LLM_MODEL_ENGINEERING_ARCHITECT_FALLBACK=kimi-k2.7-code:cloud
VCOS_LLM_MODEL_ENGINEERING_ARCHITECT_BACKUP=deepseek-v4-flash:cloud
VCOS_LLM_MODEL_GATEKEEPER_SOFT_REVIEW_PRIMARY=nemotron-3-super:cloud
VCOS_LLM_MODEL_GATEKEEPER_SOFT_REVIEW_FALLBACK=deepseek-v4-flash:cloud
VCOS_LLM_MODEL_GATEKEEPER_SOFT_REVIEW_PREMIUM=deepseek-v4-flash:cloud
